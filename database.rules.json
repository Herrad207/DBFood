{
  "rules": {
    "products": {
      ".read": "auth != null",
      ".write": false,
      ".indexOn": ["createdAt", "categoryId"]
    },
    "categories": {
      ".read": "auth != null",
      ".write": false,
      ".indexOn": ["order"]
    },
    "banners": {
      ".read": "auth != null",
      ".write": false,
      ".indexOn": ["order"]
    },
    "wishlists": {
      "$uid": {
        ".read":  "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    }
  }
}
